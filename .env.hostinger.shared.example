APP_NAME="Tema Litoclean"
APP_ENV=production
# Generar luego de copiar el archivo al hosting:
# php artisan key:generate --force
APP_KEY=
APP_DEBUG=false
APP_URL=https://gm.temalitoclean.com
ASSET_URL=https://gm.temalitoclean.com

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_PE

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=error

# Completar manualmente solo estas credenciales de base de datos de Hostinger.
DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=hostinger_db_name
DB_USERNAME=hostinger_db_user
DB_PASSWORD=hostinger_db_password

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=gm.temalitoclean.com
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file

MAIL_MAILER=smtp
MAIL_SCHEME=tls
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=587
MAIL_USERNAME=notificaciones@temalitoclean.com
MAIL_PASSWORD=Lm@03051971
MAIL_FROM_ADDRESS="notificaciones@temalitoclean.com"
MAIL_FROM_NAME="${APP_NAME}"
MAIL_EHLO_DOMAIN=gm.temalitoclean.com

TWO_FACTOR_CODE_LENGTH=6
TWO_FACTOR_EXPIRES_MINUTES=10
TWO_FACTOR_MAX_ATTEMPTS=5
TWO_FACTOR_RESEND_COOLDOWN_SECONDS=60

APP_STORAGE_DIR=storage/app/tema_litoclean
APP_AUDIT_DIR=storage/app/tema_litoclean/audit
APP_SETTINGS_JSON=storage/app/tema_litoclean/app_settings.json
APP_MAX_UPLOAD_MB=1024
APP_MAX_FILES_PER_REQUEST=10

# Mantener el frontend y la API en el mismo dominio.
VITE_API_BASE_URL=https://gm.temalitoclean.com
